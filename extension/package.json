{
  "name": "@parceldeck/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build && wxt build -b firefox",
    "zip": "wxt zip && wxt zip -b firefox",
    "icons": "node scripts/generate-icons.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@parceldeck/shared": "workspace:*",
    "webextension-polyfill": "^0.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/webextension-polyfill": "^0.12.1",
    "jsdom": "^29.0.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4",
    "wxt": "^0.19.13"
  }
}
